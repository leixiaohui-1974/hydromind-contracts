{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillExecutionPolicy",
  "type": "object",
  "required": ["schema_version", "contract_type", "policy_id", "skill_id", "entry_conditions", "required_inputs", "execution_steps", "preferred_mcp_sequence", "fallback_steps", "quality_gates", "result_schema_expectation"],
  "properties": {
    "schema_version": { "type": "string" },
    "contract_type": { "const": "SkillExecutionPolicy" },
    "policy_id": { "type": "string", "minLength": 1 },
    "skill_id": { "type": "string", "minLength": 1 },
    "entry_conditions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "required_inputs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "execution_steps": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "preferred_mcp_sequence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "fallback_steps": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "quality_gates": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "result_schema_expectation": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": true
}
