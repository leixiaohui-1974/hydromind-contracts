{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowRun",
  "type": "object",
  "required": ["schema_version", "contract_type", "case_id", "workflow_name", "canonical_workflow_key", "run_id", "status", "inputs", "outputs", "contracts_emitted", "artifacts_emitted", "started_at", "finished_at", "trace_summary"],
  "properties": {
    "schema_version": { "type": "string" },
    "contract_type": { "const": "WorkflowRun" },
    "case_id": { "type": "string" },
    "workflow_name": { "type": "string" },
    "canonical_workflow_key": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["planned", "running", "degraded", "blocked", "stopped", "completed", "failed"]
    },
    "inputs": {
      "type": "object",
      "required": ["session_id", "profile"],
      "properties": {
        "session_id": { "type": "string", "minLength": 1 },
        "profile": { "type": "string", "minLength": 1 }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["source", "terminal_status", "artifacts", "artifact_records", "provider_id", "adapter_type"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["runtime", "inferred", "inferred_session_terminal", "delegated"]
        },
        "terminal_status": {
          "type": "string",
          "enum": ["planned", "running", "degraded", "blocked", "stopped", "completed", "failed"]
        },
        "provider_id": { "type": "string", "minLength": 1 },
        "adapter_type": { "type": "string", "minLength": 1 },
        "trace_id": { "type": "string", "minLength": 1 },
        "artifacts": {
          "anyOf": [
            { "type": "object" },
            { "type": "array" }
          ]
        },
        "artifact_records": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["artifact_id", "kind", "pointer"],
            "properties": {
              "artifact_id": { "type": "string", "minLength": 1 },
              "kind": {
                "type": "string",
                "enum": [
                  "runtime.directory",
                  "runtime.run_summary",
                  "runtime.cli_result",
                  "runtime.plan",
                  "runtime.progress_stream",
                  "contract.workflow_run",
                  "contract.final_report",
                  "artifact.json",
                  "artifact.ndjson",
                  "artifact.path"
                ]
              },
              "pointer": { "type": "string", "minLength": 1 }
            }
          }
        },
        "writeback_records": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["writeback_id", "intervention_id", "surface_id", "action", "kind", "pointer", "actor", "actor_scope", "recorded_at"],
            "properties": {
              "writeback_id": { "type": "string", "minLength": 1 },
              "intervention_id": { "type": "string", "minLength": 1 },
              "surface_id": { "type": "string", "minLength": 1 },
              "action": { "type": "string", "minLength": 1 },
              "kind": {
                "type": "string",
                "enum": [
                  "writeback.report",
                  "writeback.gis",
                  "writeback.topology",
                  "writeback.parameter",
                  "writeback.source",
                  "writeback.prompt",
                  "writeback.resume",
                  "writeback.confirmation",
                  "writeback.override"
                ]
              },
              "pointer": { "type": "string", "minLength": 1 },
              "actor": { "type": "string", "minLength": 1 },
              "actor_scope": { "type": "string", "minLength": 1 },
              "recorded_at": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "contracts_emitted": { "type": "array", "items": { "type": "string" } },
    "artifacts_emitted": { "type": "array", "items": { "type": "string" } },
    "started_at": { "type": "string", "minLength": 1 },
    "finished_at": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string" },
    "trace_pointer": { "type": "string" },
    "trace_summary": { "type": "object" }
  }
}
