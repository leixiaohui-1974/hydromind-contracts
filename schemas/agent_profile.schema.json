    "display_name": { "type": "string", "minLength": 1 },
    "role_id": { "type": "string", "minLength": 1 },
    "role_profile_id": { "type": "string", "minLength": 1 },
    "lifecycle_stage_id": { "type": "string", "minLength": 1 },
    "management_level_id": { "type": "string", "minLength": 1 },
    "default_session_mode_id": { "type": "string", "minLength": 1 },
    "supported_skill_ids": {
