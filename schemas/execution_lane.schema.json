  "properties": {
    "schema_version": { "type": "string" },
    "contract_type": { "const": "ExecutionLane" },
    "lane_id": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "provider_id": { "type": "string", "minLength": 1 },
    "adapter_type": { "type": "string", "minLength": 1 },
    "supported_workflows": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "supported_canonical_workflow_keys": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "runtime_class": { "type": "string", "minLength": 1 },
    "dispatch_mode": { "type": "string", "minLength": 1 },
    "artifact_root_kind": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
