  "properties": {
    "schema_version": { "type": "string" },
    "contract_type": { "const": "RoleProfile" },
    "role_profile_id": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "lifecycle_stage_id": { "type": "string", "minLength": 1 },
    "default_management_level_id": { "type": "string", "minLength": 1 },
    "workflow_focus": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
