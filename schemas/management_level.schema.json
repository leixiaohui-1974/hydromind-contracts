{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ManagementLevel",
  "type": "object",
  "required": ["schema_version", "contract_type", "management_level_id", "display_name", "scope", "responsibilities"],
  "properties": {
    "schema_version": { "type": "string" },
    "contract_type": { "const": "ManagementLevel" },
    "management_level_id": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "minLength": 1 },
    "responsibilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
